# =============================================================================
# AKSCI Morningstar — Environment Configuration
# =============================================================================
# Copy to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# ── Server ──────────────────────────────────────────────────────────────
PORT=3456
NODE_ENV=development
LOG_LEVEL=info
SESSION_SECRET=morningstar-session-dev-change-me
CORS_ORIGIN=true
RATE_LIMIT_MAX=200

# ── Database (PostgreSQL + pgvector) ────────────────────────────────────
DATABASE_URL=postgres://morningstar:morningstar@localhost:5432/morningstar
DB_POOL_SIZE=10

# ── Redis (caching + Bull job queue) ────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── LLM Provider (set at least one API key for real intelligence) ──────
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Google OAuth (Calendar, Gmail, Meet) ────────────────────────────────
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=http://localhost:3456/api/auth/google/callback

# ── SMTP (email fallback when Google not configured) ────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=app-password-here

# ── Simulation (Python microservice) ────────────────────────────────────
SIMULATION_HOST=localhost
SIMULATION_PORT=8000

# ── Firebase Cloud Messaging (push notifications) ──────────────────────
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
